// Seven Generation LMS — Prisma schema
// Datasource: PostgreSQL (Neon in prod, local Postgres or `npx prisma dev` in dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ============================================================
// AUTH.js standard tables (magic-link via Resend, no OAuth yet)
// ============================================================

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// ORG: Entity, User, Manager hierarchy
// ============================================================

enum UserRole {
  EMPLOYEE
  MANAGER
  ADMIN
}

model Entity {
  id        String   @id @default(cuid())
  code      String   @unique // "M2", "MMI", "RDB", "7GEN"
  name      String   // e.g. "M2.0 Communications"
  users     User[]
  createdAt DateTime @default(now())
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?

  role     UserRole @default(EMPLOYEE)
  entityId String?
  entity   Entity?  @relation(fields: [entityId], references: [id])

  managerId String?
  manager   User?   @relation("ManagerReports", fields: [managerId], references: [id])
  reports   User[]  @relation("ManagerReports")

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // LMS relations
  ownedPrograms       Program[]        @relation("ProgramOwner")
  enrollments         Enrollment[]
  submissions         Submission[]
  reviewedSubmissions Submission[]     @relation("Reviewer")
  moduleProgress      ModuleProgress[]
  sectionViews        SectionView[]
  quizAnswers         QuizAnswer[]
  bookmarks           Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([entityId])
  @@index([managerId])
  @@index([role])
}

// ============================================================
// PROGRAMS (top-level container, e.g. "Claude at Work")
// ============================================================

model Program {
  id          String  @id @default(cuid())
  slug        String  @unique
  title       String
  subtitle    String?
  description String? @db.Text

  ownerId String
  owner   User   @relation("ProgramOwner", fields: [ownerId], references: [id])

  startDate DateTime?
  endDate   DateTime?

  // Audience filter rules — evaluated by /lib/audience to materialize enrollments.
  // Shape: { entities: ["M2","MMI"], roles: ["EMPLOYEE"], userIds: [...], managerIds: [...] }
  audienceRules Json?

  archivedAt DateTime?

  modules     Module[]
  enrollments Enrollment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Enrollment {
  id         String   @id @default(cuid())
  userId     String
  programId  String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  program    Program  @relation(fields: [programId], references: [id], onDelete: Cascade)
  enrolledAt DateTime @default(now())

  @@unique([userId, programId])
  @@index([programId])
}

// ============================================================
// MODULES (ordered children of a Program)
// ============================================================

enum ModuleLevel {
  FOUNDATION
  INTERMEDIATE
  ADVANCED
  MASTERY
}

model Module {
  id              String      @id @default(cuid())
  programId       String
  program         Program     @relation(fields: [programId], references: [id], onDelete: Cascade)

  position        Int         // ordering within program
  number          String      // displayed e.g. "01"
  title           String
  subtitle        String?
  heroSubtitle    String?     @db.Text
  level           ModuleLevel
  durationMinutes Int?
  audienceLabel   String?     // e.g. "All employees — M2, MMI, RDB"

  availableFrom DateTime?

  // string array of objectives (rendered in the "What you'll learn" box)
  learningObjectives Json

  sections    Section[]
  quizzes     Quiz[]
  exercise    Exercise?
  progress    ModuleProgress[]
  submissions Submission[]
  bookmarks   Bookmark[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([programId, position])
}

// ============================================================
// SECTION blocks (polymorphic — type drives the renderer)
// ============================================================

enum SectionType {
  TEXT
  OBJECTIVES_BOX
  COMPARISON
  EXAMPLE_CARD
  PROMPT_BLOCK
  TRY_IT
  CALLOUT
}

model Section {
  id       String      @id @default(cuid())
  moduleId String
  module   Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  position Int
  number   String?     // displayed "Section 01"
  title    String?
  type     SectionType
  // Content shape per type:
  //  TEXT            -> { paragraphs: Array<{ html: string }> }
  //  OBJECTIVES_BOX  -> { label: string, items: string[] }
  //  COMPARISON      -> { goodLabel, goodText, badLabel, badText, mono?: boolean }
  //  EXAMPLE_CARD    -> { label, intro?, checklist?: string[], promptBlock?: { caption?, body } }
  //  PROMPT_BLOCK    -> { caption?, body }
  //  TRY_IT          -> { tag, title, intro?, steps: string[] }
  //  CALLOUT         -> { variant: "info"|"warn"|"success", title?, body: string }
  content Json

  views SectionView[]

  @@unique([moduleId, position])
}

// ============================================================
// QUIZ + answer history
// ============================================================

model Quiz {
  id           String @id @default(cuid())
  moduleId     String
  module       Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  position     Int
  question     String @db.Text
  options      Json   // string array
  correctIndex Int
  feedback     String @db.Text // shown after answer

  answers QuizAnswer[]

  @@unique([moduleId, position])
}

// ============================================================
// EXERCISE (one per module, optional)
// ============================================================

model Exercise {
  id       String @id @default(cuid())
  moduleId String @unique
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)

  title String?
  // Shape: { intro?: string, steps: string[], deadlineNote?: string }
  instructions       Json
  deadlineOffsetDays Int? // days from module unlock to submission deadline
}

// ============================================================
// SUBMISSIONS + review queue
// ============================================================

enum SubmissionStatus {
  PENDING
  APPROVED
  REVISION_REQUESTED
}

model Submission {
  id            String           @id @default(cuid())
  userId        String
  user          User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId      String
  module        Module           @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  content       String           @db.Text
  status        SubmissionStatus @default(PENDING)
  reviewerId    String?
  reviewer      User?            @relation("Reviewer", fields: [reviewerId], references: [id])
  reviewerNotes String?          @db.Text
  submittedAt   DateTime         @default(now())
  reviewedAt    DateTime?

  @@index([userId])
  @@index([moduleId])
  @@index([status])
}

// ============================================================
// PROGRESS tracking (granular relational, not JSON arrays)
// ============================================================

model ModuleProgress {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId    String
  module      Module    @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@unique([userId, moduleId])
  @@index([userId])
}

model SectionView {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sectionId String
  section   Section  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  viewedAt  DateTime @default(now())

  @@unique([userId, sectionId])
}

model QuizAnswer {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quizId      String
  quiz        Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  choiceIndex Int
  correct     Boolean
  answeredAt  DateTime @default(now())

  @@unique([userId, quizId])
}

// ============================================================
// BOOKMARKS — learners can save a module to revisit later
// ============================================================

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, moduleId])
  @@index([userId])
}
